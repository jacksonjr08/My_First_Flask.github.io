<!DOCTYPE html>
<html>
<head>
    <title>Favorite Things Form</title>
</head>
<body>
    <form action="/results" method="POST">
        <h2>A Few Of My Favorite Things</h2>

        <label>Favorite Color:
            <input type="text" name="color">
        </label><br>

        <label>Lucky Number:
            <input type="number" name="luck_num">
        </label><br>

        <label>Favorite Class:
            <input type="text" name="fav_class">
        </label><br>

        <label>Favorite Pixar Movie:
            <input type="text" name="best_pix">
        </label><br>

        <button type="submit">Submit</button>
    </form>
</body>
</html>
