from flask import Flask, render_template, request

app = Flask(__name__)
app.config['DEBUG'] = True

@app.route('/form')
def form():
    return render_template('favorite_form.html')

@app.route('/results', methods=['POST'])
def results():
    # Get form data
    color = request.form['color'].lower().strip()
    luck_num = request.form['luck_num']
    fav_class = request.form['fav_class']
    best_pix = request.form['best_pix'].lower().strip()

    # Valid Pixar movies list
    films = [
        "toy story","a bug's life","toy story 2","monsters, inc.",
        "finding nemo","the incredibles","cars","ratatouille","wall-e","up",
        "toy story 3","cars 2","brave","monsters university","inside out",
        "the good dinosaur","finding dory","cars 3","coco","incredibles 2",
        "toy story 4","onward","soul"
    ]

    # Validate Pixar movie
    if best_pix not in films:
        best_pix = f"Sorry, '{best_pix.title()}' is not a Pixar movie."
    else:
        best_pix = best_pix.title()

    # Validate color (only allow red, green, blue)
    valid_colors = ['red', 'green', 'blue']
    if color not in valid_colors:
        color = f"Invalid color '{color}'. Choose red, green, or blue."
    else:
        color = color.title()

    return render_template(
        'form_results.html',
        color=color,
        luck_num=luck_num,
        fav_class=fav_class,
        best_pix=best_pix
    )

if __name__ == '__main__':
    app.run()
